{
  "name": "rathe-arsenal",
  "version": "0.0.0",
  "private": true,
  "description": "Flesh and Blood deck readiness tool with tier 1 substitution engine",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @rathe-arsenal/api dev\" \"pnpm --filter @rathe-arsenal/web dev\"",
    "build": "pnpm --filter @rathe-arsenal/web build && pnpm --filter @rathe-arsenal/api build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "purge:deleted-users": "node node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/dist/cli.mjs scripts/purge-deleted-users.ts",
    "gold:sample": "node node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/dist/cli.mjs scripts/gold-set/sample-decks.ts",
    "gold:generate": "node node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/dist/cli.mjs scripts/gold-set/generate-candidates.ts",
    "gold:export": "node node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/dist/cli.mjs scripts/gold-set/export-csv.ts",
    "gold:score": "node node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/dist/cli.mjs scripts/gold-set/score.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity": "^3.1027.0",
    "@types/aws4": "^1.11.6",
    "aws4": "^1.13.2",
    "concurrently": "^9.1.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "yaml": "^2.8.3"
  }
}
