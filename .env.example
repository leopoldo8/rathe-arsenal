# ---- App ----
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:5173

# ---- Database (Railway Postgres provides this automatically in prod) ----
DATABASE_URL=postgresql://postgres:dev@localhost:5432/rathe_arsenal

# ---- Auth (DIY: passport-jwt + bcrypt) ----
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_64_char_random_hex
# Optional. Defaults to 7d in code. Format: <number><s|m|h|d>
JWT_EXPIRES_IN=7d

# ---- Email (Resend — https://resend.com — free 100/day) ----
RESEND_API_KEY=re_replace_me
# For Phase 0 testing without verifying a domain, you can use:
#   EMAIL_FROM=onboarding@resend.dev
# For production, verify your domain in the Resend dashboard first.
EMAIL_FROM=Rathe Arsenal <onboarding@resend.dev>

# ---- Fabrary AppSync (validated 2026-04-08, see docs/research/) ----
AWS_APPSYNC_ENDPOINT=https://42xrd23ihbd47fjvsrt27ufpfe.appsync-api.us-east-2.amazonaws.com/graphql
COGNITO_IDENTITY_POOL_ID=us-east-2:e50f3ed7-32ed-4b22-a05e-10b3e7e03fe0
COGNITO_REGION=us-east-2

# ---- Fetch guard allow-list (comma-separated hosts) ----
FABRARY_ALLOW_HOSTS=fabrary.net,42xrd23ihbd47fjvsrt27ufpfe.appsync-api.us-east-2.amazonaws.com,cognito-identity.us-east-2.amazonaws.com
